<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NetBuddies.App.ViewModels"
        x:Class="NetBuddies.App.Views.WebGameWindow"
        x:DataType="vm:WebGameViewModel"
        Title="{Binding Title}"
        Width="900"
        Height="680"
        MinWidth="640"
        MinHeight="480">
    <Grid RowDefinitions="Auto,*"
          Background="{DynamicResource NbPageBrush}">
        <Border Background="{DynamicResource NbHeaderBrush}"
                BorderBrush="{DynamicResource NbHeaderBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <StackPanel>
                    <TextBlock Text="{Binding GameName}"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="Bold"/>
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="#E8F7FF"
                               TextWrapping="Wrap"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="End Game"
                        Command="{Binding EndGameCommand}"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>
        <Grid x:Name="GameHost"
              Grid.Row="1">
            <Border x:Name="FallbackPanel"
                    IsVisible="False"
                    Margin="24"
                    Padding="24"
                    Background="{DynamicResource NbPanelBrush}"
                    BorderBrush="{DynamicResource NbPanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MaxWidth="520">
                <StackPanel Spacing="12">
                    <TextBlock Text="This game could not be opened inside Net Buddies on this machine."
                               FontSize="18"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource NbTextBrush}"/>
                    <TextBlock x:Name="FallbackReasonText"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource NbMutedTextBrush}"/>
                    <TextBlock Text="The game can still run in your browser using the same room invite."
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource NbMutedTextBrush}"/>
                    <Button Content="Open Game"
                            Command="{Binding OpenExternallyCommand}"
                            HorizontalAlignment="Left"/>
                    <TextBlock Text="{Binding LaunchStatusText}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource NbWarningBrush}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
