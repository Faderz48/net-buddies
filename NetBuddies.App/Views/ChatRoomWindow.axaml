<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NetBuddies.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="820"
        d:DesignHeight="740"
        Width="820"
        Height="740"
        MinWidth="620"
        MinHeight="560"
        x:Class="NetBuddies.App.Views.ChatRoomWindow"
        x:DataType="vm:ChatRoomViewModel"
        Title="{Binding RoomName}">

    <Window.Styles>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{DynamicResource NbPrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="{DynamicResource NbCardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource NbCardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*"
          Background="{DynamicResource NbPageBrush}">
        <Border Background="{DynamicResource NbHeaderBrush}"
                Padding="14"
                BorderBrush="{DynamicResource NbHeaderBorderBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="{Binding RoomName}"
                           Foreground="White"
                           FontSize="26"
                           FontWeight="Bold"/>
                <TextBlock Text="Chat room and optional voice channel"
                           Foreground="#E8F7FF"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1"
              Margin="12"
              ColumnDefinitions="*,240"
              RowDefinitions="*,Auto"
              ColumnSpacing="12"
              RowSpacing="12">
            <Border Classes="panel">
                <ScrollViewer x:Name="MessageScrollViewer">
                    <ItemsControl ItemsSource="{Binding Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:RoomMessageLineViewModel">
                                <Border Background="{DynamicResource NbMessageBrush}"
                                        BorderBrush="{DynamicResource NbMessageBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="9"
                                        Margin="0,0,0,7">
                                    <Grid ColumnDefinitions="44,*"
                                          ColumnSpacing="9">
                                        <Border Width="36"
                                                Height="36"
                                                Background="{DynamicResource NbAvatarBrush}"
                                                BorderBrush="{DynamicResource NbAvatarBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                VerticalAlignment="Top">
                                            <Grid>
                                                <Ellipse Width="17" Height="17" Fill="#FFD1A5" VerticalAlignment="Top" Margin="0,4,0,0"/>
                                                <Ellipse Width="25" Height="16" Fill="#2F9BE4" VerticalAlignment="Bottom" Margin="0,0,0,3"/>
                                                <Image Source="{Binding AvatarImage}"
                                                       Stretch="UniformToFill"/>
                                            </Grid>
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="3">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Text="{Binding Sender}"
                                                           Foreground="{DynamicResource NbTextBrush}"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Stamp}"
                                                           Foreground="{DynamicResource NbSubtleTextBrush}"
                                                           FontSize="12"
                                                           Margin="8,0,0,0"/>
                                            </Grid>
                                            <TextBlock Text="{Binding Body}"
                                                       Foreground="{DynamicResource NbStrongTextBrush}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <ScrollViewer Grid.Column="1"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="12">
                    <Border Classes="panel">
                        <StackPanel Spacing="8">
                            <TextBlock Text="People"
                                       Foreground="{DynamicResource NbTextBrush}"
                                       FontWeight="Bold"/>
                            <ListBox ItemsSource="{Binding Participants}"
                                     MinHeight="110"
                                     MaxHeight="180"/>
                        </StackPanel>
                    </Border>

                    <Border Classes="panel">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Voice Channel"
                                       Foreground="{DynamicResource NbTextBrush}"
                                       FontWeight="Bold"/>
                            <ComboBox ItemsSource="{Binding Microphones}"
                                      SelectedItem="{Binding SelectedMicrophone}"
                                      DisplayMemberBinding="{Binding Name}"
                                      PlaceholderText="Select microphone"/>
                            <CheckBox Content="Echo cancellation"
                                      IsChecked="{Binding EchoCancellationEnabled}"/>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                <Button Content="Join Voice"
                                        Classes="primary"
                                        Command="{Binding JoinVoiceCommand}"/>
                                <Button Grid.Column="1"
                                        Content="Leave"
                                        Command="{Binding LeaveVoiceCommand}"/>
                            </Grid>
                            <TextBlock Text="{Binding VoiceStatus}"
                                       Foreground="{DynamicResource NbSubtleTextBrush}"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="Mic activity"
                                       Foreground="{DynamicResource NbTextBrush}"
                                       FontWeight="SemiBold"
                                       Margin="0,4,0,0"/>
                            <ProgressBar Minimum="0"
                                         Maximum="100"
                                         Value="{Binding MicrophoneLevel}"
                                         Height="12"/>
                            <TextBlock Text="In voice"
                                       Foreground="{DynamicResource NbTextBrush}"
                                       FontWeight="Bold"
                                       Margin="0,6,0,0"/>
                            <ListBox ItemsSource="{Binding VoiceParticipants}"
                                     MinHeight="80"
                                     MaxHeight="150"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Classes="panel">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <TextBox x:Name="MessageInput"
                             Text="{Binding DraftMessage}"
                             PlaceholderText="Message this room..."
                             AcceptsReturn="True"
                             KeyDown="MessageInput_KeyDown"
                             MinHeight="64"
                             TextWrapping="Wrap"/>
                    <Button Grid.Column="1"
                            Content="Send"
                            Classes="primary"
                            Command="{Binding SendMessageCommand}"
                            MinWidth="96"
                            VerticalAlignment="Stretch"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
