<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="using:NetBuddies.App.Services"
        Width="520"
        Height="500"
        MinWidth="420"
        MinHeight="380"
        x:Class="NetBuddies.App.Views.GamesLibraryWindow"
        x:CompileBindings="False"
        Icon="/Assets/netbuddies.ico"
        Title="Net Buddies Games">

    <Window.Styles>
        <Style Selector="Border.gameCard">
            <Setter Property="Background" Value="{DynamicResource NbCardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource NbCardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
        </Style>
        <Style Selector="Border.gameIcon">
            <Setter Property="Width" Value="58"/>
            <Setter Property="Height" Value="58"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderBrush" Value="{DynamicResource NbMessageBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource NbPanelBrush}"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto"
          Background="{DynamicResource NbPageBrush}">
        <Border Background="{DynamicResource NbHeaderBrush}"
                Padding="14"
                BorderBrush="{DynamicResource NbHeaderBorderBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="Games"
                           Foreground="White"
                           FontSize="26"
                           FontWeight="Bold"/>
                <TextBlock Text="Drop game folders into your Net Buddies games folder to add or override assets."
                           Foreground="#E8F7FF"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      Margin="12"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="services:GameCatalogItem">
                        <Border Classes="gameCard"
                                Margin="0,0,0,10">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Border Classes="gameIcon">
                                    <Image Source="{Binding Icon}"
                                           Stretch="UniformToFill"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{DynamicResource NbStrongTextBrush}"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding SourceLabel}"
                                                   Foreground="{DynamicResource NbSubtleTextBrush}"
                                                   FontSize="12"/>
                                    </Grid>
                                    <TextBlock Text="{Binding Description}"
                                               Foreground="{DynamicResource NbSubtleTextBrush}"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding PlayModeLabel}"
                                               Foreground="{DynamicResource NbSubtleTextBrush}"
                                               FontSize="12"/>
                                    <TextBlock Text="{Binding FolderPath}"
                                               Foreground="{DynamicResource NbSubtleTextBrush}"
                                               FontSize="11"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="{DynamicResource NbPanelBrush}"
                BorderBrush="{DynamicResource NbMessageBorderBrush}"
                BorderThickness="1,1,0,0"
                Padding="12">
            <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="8">
                <Button Content="Open Games Folder"
                        MinWidth="140"
                        Click="OpenGamesFolder_Click"/>
                <Button Grid.Column="1"
                        Content="Refresh"
                        MinWidth="90"
                        Click="Refresh_Click"/>
                <Button Grid.Column="2"
                        Content="Close"
                        HorizontalAlignment="Right"
                        MinWidth="96"
                        Click="Close_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
