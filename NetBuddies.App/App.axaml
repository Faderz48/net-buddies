<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="NetBuddies.App.App"
             xmlns:local="using:NetBuddies.App"
             RequestedThemeVariant="Light">
             <!-- Keep Net Buddies on its own MSN-style light theme instead of following the Windows theme. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>
