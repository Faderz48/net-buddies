<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="NetBuddies.Server.Gui.MainWindow"
        Title="Net Buddies Server"
        Width="760"
        Height="720"
        MinWidth="620"
        MinHeight="560"
        Background="#101A26">
    <Window.Styles>
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="#172434"/>
            <Setter Property="BorderBrush" Value="#365A79"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14"/>
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="Foreground" Value="#8CC9FF"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#1F8FE5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*"
          Background="#101A26">
        <Border Background="#075A9F"
                BorderBrush="#0A477A"
                BorderThickness="0,0,0,1"
                Padding="16">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                <Image Source="/Assets/netbuddies-64.png"
                       Width="54"
                       Height="54"
                       Stretch="Uniform"/>
                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Net Buddies Server"
                               Foreground="White"
                               FontSize="28"
                               FontWeight="Bold"/>
                    <TextBlock x:Name="HeaderStatusText"
                               Text="Ready to host"
                               Foreground="#E8F7FF"/>
                </StackPanel>
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <Ellipse x:Name="ServerStatusDot"
                             Width="14"
                             Height="14"
                             Fill="#D64545"/>
                    <TextBlock x:Name="ServerStatusDotText"
                               Text="Offline"
                               Foreground="#E8F7FF"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      Margin="14"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">
                <Border Classes="panel">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Server"
                                   Foreground="#E8F4FF"
                                   FontSize="20"
                                   FontWeight="Bold"/>
                        <Grid ColumnDefinitions="*,160,160" ColumnSpacing="10">
                            <StackPanel>
                                <TextBlock Text="BIND ADDRESS" Classes="label"/>
                                <TextBox x:Name="BindAddressBox"
                                         Text="0.0.0.0"
                                         PlaceholderText="0.0.0.0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="SERVER PORT" Classes="label"/>
                                <NumericUpDown x:Name="PortBox"
                                               Value="5050"
                                               Minimum="1"
                                               Maximum="65535"
                                               Increment="1"
                                               MinWidth="150"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" IsVisible="False">
                                <TextBlock Text="PUBLIC TLS PORT" Classes="label"/>
                                <NumericUpDown x:Name="StunnelPortBox"
                                               Value="5051"
                                               Minimum="1"
                                               Maximum="65535"
                                               Increment="1"
                                               MinWidth="150"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="INVITE CODE" Classes="label"/>
                        <TextBox x:Name="InviteCodeBox"
                                 PasswordChar="*"
                                 PlaceholderText="Optional"/>
                        <TextBlock Text="TLS MODE" Classes="label"/>
                        <ComboBox x:Name="TlsModeBox"
                                  SelectedIndex="1"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="TlsMode_Changed">
                            <ComboBoxItem Content="No TLS - private LAN or tunnel"/>
                            <ComboBoxItem Content="Built-in Net Buddies TLS - recommended"/>
                        </ComboBox>
                        <TextBlock Text="Recommended: Built-in Net Buddies TLS. No stunnel or external TLS wrapper is needed. Clients connect to the server port with Use TLS enabled."
                                   Foreground="#B9D0E4"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Classes="panel">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Certificates"
                                   Foreground="#E8F4FF"
                                   FontSize="20"
                                   FontWeight="Bold"/>
                        <Grid ColumnDefinitions="*,180" ColumnSpacing="10">
                            <StackPanel>
                                <TextBlock Text="PFX CERTIFICATE FOR .NET TLS" Classes="label"/>
                                <TextBox x:Name="PfxPathBox"
                                         PlaceholderText="Select or generate a .pfx file"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="PFX PASSWORD" Classes="label"/>
                                <TextBox x:Name="CertificatePasswordBox"
                                         PasswordChar="*"
                                         PlaceholderText="Password"/>
                            </StackPanel>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                            <StackPanel>
                                <TextBlock Text="SERVER CERTIFICATE FINGERPRINT" Classes="label"/>
                                <TextBox x:Name="StunnelPemPathBox"
                                         IsReadOnly="True"
                                         PlaceholderText="Generated SHA-256 fingerprint"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="Browse PEM"
                                    Click="BrowsePem_Click"
                                    IsVisible="False"
                                    VerticalAlignment="Bottom"
                                    MinWidth="110"/>
                            <Button Grid.Column="2"
                                    Content="Browse PFX"
                                    Click="BrowsePfx_Click"
                                    VerticalAlignment="Bottom"
                                    MinWidth="110"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                            <TextBox x:Name="CertificateHostBox"
                                     PlaceholderText="Certificate name"
                                     Text="netbuddies.local"/>
                            <Button Grid.Column="1"
                                    Content="Generate Certs"
                                    Click="GenerateCertificates_Click"
                                    MinWidth="130"/>
                            <Button Grid.Column="2"
                                    Content="Save stunnel config"
                                    Click="SaveStunnelConfig_Click"
                                    IsVisible="False"
                                    MinWidth="150"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                            <Button Content="Quick Built-in TLS Setup"
                                    Classes="primary"
                                    Click="QuickTlsSetup_Click"
                                    MinHeight="38"/>
                            <Button Grid.Column="1"
                                    Content="Check stunnel"
                                    Click="CheckStunnel_Click"
                                    IsVisible="False"
                                    MinWidth="120"/>
                            <Button Grid.Column="2"
                                    Content="Copy install command"
                                    Click="CopyInstallCommand_Click"
                                    IsVisible="False"
                                    MinWidth="165"/>
                        </Grid>
                        <TextBlock x:Name="TlsSetupStatusText"
                                   Text="Quick Built-in TLS Setup generates a certificate and prepares secure hosting without installing stunnel."
                                   Foreground="#B9D0E4"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Classes="panel">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Controls"
                                   Foreground="#E8F4FF"
                                   FontSize="20"
                                   FontWeight="Bold"/>
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                            <Button Content="Start Server"
                                    Classes="primary"
                                    Click="StartServer_Click"
                                    MinHeight="42"/>
                            <Button Grid.Column="1"
                                    Content="Stop Server"
                                    Click="StopServer_Click"
                                    MinHeight="42"/>
                            <Button Grid.Column="2"
                                    Content="Open Cert Folder"
                                    Click="OpenCertificateFolder_Click"
                                    MinHeight="42"/>
                        </Grid>
                        <TextBlock x:Name="ConnectionHintText"
                                   Foreground="#B9D0E4"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Classes="panel">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Real-Time Game Server"
                                   Foreground="#E8F4FF"
                                   FontSize="20"
                                   FontWeight="Bold"/>
                        <CheckBox x:Name="RealtimeEnabledBox"
                                  Content="Start real-time game rooms with the Net Buddies server"
                                  Foreground="#E8F4FF"
                                  IsChecked="True"/>
                        <Grid ColumnDefinitions="*,160,160" ColumnSpacing="10">
                            <StackPanel>
                                <TextBlock Text="PUBLIC GAME SERVER URL" Classes="label"/>
                                <TextBox x:Name="RealtimePublicUrlBox"
                                         Text="ws://127.0.0.1:2568"
                                         PlaceholderText="ws://your-server-ip:2568"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="GAME PORT" Classes="label"/>
                                <NumericUpDown x:Name="RealtimePortBox"
                                               Value="2567"
                                               Minimum="1"
                                               Maximum="65535"
                                               Increment="1"
                                               MinWidth="150"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="BIND ADDRESS" Classes="label"/>
                                <TextBox x:Name="RealtimeBindBox"
                                         Text="0.0.0.0"
                                         PlaceholderText="0.0.0.0"/>
                            </StackPanel>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="10">
                            <TextBlock x:Name="RealtimeStatusText"
                                       Text="Colyseus rooms: lobby, Buddy Pong, Snake Battle. Install dependencies once, then Start Server."
                                       Foreground="#B9D0E4"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="Install/update"
                                    Click="InstallRealtimeDependencies_Click"
                                    MinWidth="130"/>
                            <Button Grid.Column="2"
                                    Content="Check Node"
                                    Click="CheckNode_Click"
                                    MinWidth="110"/>
                            <Button Grid.Column="3"
                                    Content="Open folder"
                                    Click="OpenRealtimeFolder_Click"
                                    MinWidth="110"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <StackPanel>
                                <TextBlock Text="DETECTED MODULAR GAMES" Classes="label"/>
                                <TextBox x:Name="RealtimeGamesBox"
                                         MinHeight="88"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         FontFamily="Consolas"
                                         Text="No games scanned yet."/>
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        Spacing="8"
                                        VerticalAlignment="Bottom">
                                <Button Content="Refresh games"
                                        Click="RefreshRealtimeGames_Click"
                                        MinWidth="130"/>
                                <Button Content="Open games"
                                        Click="OpenRealtimeGamesFolder_Click"
                                        MinWidth="130"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Classes="panel" IsVisible="False">
                    <StackPanel Spacing="8">
                        <TextBlock Text="stunnel Config Preview"
                                   Foreground="#E8F4FF"
                                   FontSize="18"
                                   FontWeight="Bold"/>
                        <TextBox x:Name="StunnelConfigBox"
                                 AcceptsReturn="True"
                                 IsReadOnly="True"
                                 MinHeight="130"
                                 TextWrapping="NoWrap"
                                 FontFamily="Consolas,monospace"/>
                    </StackPanel>
                </Border>

                <Border Classes="panel">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Server Log"
                                   Foreground="#E8F4FF"
                                   FontSize="18"
                                   FontWeight="Bold"/>
                        <TextBox x:Name="LogBox"
                                 AcceptsReturn="True"
                                 IsReadOnly="True"
                                 MinHeight="180"
                                 TextWrapping="Wrap"
                                 FontFamily="Consolas,monospace"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
